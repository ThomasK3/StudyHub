          "content": {
            "size": 9126,
            "mimeType": "text/css",
            "compression": 0,
            "text": "/* ==========================================================================\n   StudyHub — Course form styles\n   ========================================================================== */\n\n/* ── Layout ───────────────────────────────────────────────────────────────── */\n\n.course-form {\n  max-width: 820px;\n}\n\n.form-header {\n  margin-bottom: var(--space-6);\n}\n\n.form-section {\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  padding: var(--space-5);\n  margin-bottom: var(--space-5);\n}\n\n.form-section__title {\n  font-family: var(--font-heading);\n  font-weight: var(--weight-bold);\n  font-size: var(--text-md);\n  text-transform: uppercase;\n  letter-spacing: 0.03em;\n  color: var(--color-text);\n  margin-bottom: var(--space-4);\n}\n\n.form-section__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: var(--space-4);\n}\n\n.form-section__header .form-section__title {\n  margin-bottom: 0;\n}\n\n/* ── Form fields ──────────────────────────────────────────────────────────── */\n\n.form-label {\n  display: block;\n  font-size: var(--text-sm);\n  font-weight: var(--weight-semibold);\n  color: var(--color-text);\n  margin-bottom: var(--space-1);\n}\n\n.form-field {\n  margin-bottom: var(--space-4);\n  flex: 1;\n  min-width: 0;\n}\n\n.form-field--sm { flex: 0 0 160px; }\n.form-field--xs { flex: 0 0 100px; }\n\n.form-row {\n  display: flex;\n  gap: var(--space-4);\n  flex-wrap: wrap;\n}\n\n@media (max-width: 639px) {\n  .form-row { flex-direction: column; }\n  .form-field--sm,\n  .form-field--xs { flex: 1; }\n}\n\n/* ── Catalog search dropdown ──────────────────────────────────────────────── */\n\n.catalog-search {\n  position: relative;\n}\n\n.catalog-dropdown {\n  display: none;\n  position: absolute;\n  top: 100%;\n  left: 0;\n  right: 0;\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-top: none;\n  border-radius: 0 0 var(--radius-md) var(--radius-md);\n  max-height: 260px;\n  overflow-y: auto;\n  z-index: 50;\n  box-shadow: var(--shadow-md);\n}\n\n.catalog-dropdown--open {\n  display: block;\n}\n\n.catalog-item {\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n  padding: var(--space-2) var(--space-3);\n  font-size: var(--text-sm);\n  cursor: pointer;\n  transition: background-color var(--transition-fast);\n}\n\n.catalog-item:hover {\n  background-color: var(--color-teal-light);\n}\n\n.catalog-item--custom {\n  border-bottom: var(--border-width) solid var(--color-border);\n}\n\n/* ── Weight sum indicator ─────────────────────────────────────────────────── */\n\n.weight-sum {\n  font-family: var(--font-mono);\n  font-size: var(--text-sm);\n  font-weight: var(--weight-semibold);\n  padding: var(--space-1) var(--space-3);\n  border-radius: var(--radius-full);\n}\n\n.weight-sum--ok {\n  background-color: var(--color-green-light);\n  color: var(--color-green);\n}\n\n.weight-sum--warn {\n  background-color: var(--color-amber-light);\n  color: var(--color-warning-text);\n}\n\n/* ── Dynamic rows ─────────────────────────────────────────────────────────── */\n\n.dyn-row {\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  padding: var(--space-3);\n  margin-bottom: var(--space-3);\n  background-color: var(--color-off-white);\n}\n\n.dyn-row__fields {\n  display: flex;\n  gap: var(--space-3);\n  flex-wrap: wrap;\n}\n\n.dyn-row__fields .form-field {\n  margin-bottom: var(--space-2);\n}\n\n.dyn-row__bottom {\n  display: flex;\n  gap: var(--space-3);\n  align-items: flex-start;\n}\n\n.dyn-row__bottom .textarea,\n.dyn-row__bottom .input {\n  flex: 1;\n}\n\n.dyn-row--simple {\n  display: flex;\n  gap: var(--space-3);\n  align-items: center;\n}\n\n.dyn-row--simple .input {\n  flex: 1;\n}\n\n@media (max-width: 639px) {\n  .dyn-row__fields { flex-direction: column; }\n  .dyn-row__fields .form-field--sm,\n  .dyn-row__fields .form-field--xs { flex: 1; }\n}\n\n/* ── Small textarea ───────────────────────────────────────────────────────── */\n\n.textarea--sm {\n  min-height: 36px;\n  resize: vertical;\n}\n\n/* ── Delete button (icon) ─────────────────────────────────────────────────── */\n\n.btn-icon {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  width: 32px;\n  height: 32px;\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  background: var(--color-white);\n  cursor: pointer;\n  font-size: var(--text-lg);\n  line-height: 1;\n  transition: background-color var(--transition-fast), color var(--transition-fast), border-color var(--transition-fast);\n  flex-shrink: 0;\n  color: var(--color-muted);\n}\n\n.btn-icon--delete:hover {\n  background-color: var(--color-red-light);\n  border-color: var(--color-red);\n  color: var(--color-red);\n}\n\n/* ── Grading edit grid ────────────────────────────────────────────────────── */\n\n.grade-edit-grid {\n  display: flex;\n  gap: var(--space-3);\n  flex-wrap: wrap;\n}\n\n.grade-edit-cell {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2);\n}\n\n.grade-edit-cell__grade {\n  font-family: var(--font-heading);\n  font-weight: var(--weight-extrabold);\n  font-size: var(--text-lg);\n  width: 24px;\n  text-align: center;\n}\n\n.grade-edit-cell__input {\n  width: 64px;\n}\n\n/* ── Form actions ─────────────────────────────────────────────────────────── */\n\n.form-actions {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: var(--space-4);\n  padding: var(--space-4) 0;\n  flex-wrap: wrap;\n}\n\n.form-actions > div {\n  display: flex;\n  gap: var(--space-3);\n}\n\n.btn--danger {\n  background-color: transparent;\n  color: var(--color-red);\n  border: var(--border-width) solid var(--color-red);\n  font-family: var(--font-body);\n  font-size: var(--text-sm);\n  font-weight: var(--weight-semibold);\n  padding: var(--space-2) var(--space-4);\n  border-radius: var(--radius-md);\n  cursor: pointer;\n  transition: background-color var(--transition-fast);\n}\n\n.btn--danger:hover {\n  background-color: var(--color-red-light);\n}\n\n/* ── Weekly topics grid ───────────────────────────────────────────────────── */\n\n.weekly-topics-grid {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-2);\n}\n\n.weekly-topic-row {\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n}\n\n.weekly-topic-row__week {\n  width: 28px;\n  text-align: right;\n  flex-shrink: 0;\n  font-size: var(--text-sm);\n}\n\n/* ── Grade edit label ────────────────────────────────────────────────────── */\n\n.grade-edit-cell__label {\n  min-width: 70px;\n}\n\n/* ── Shared course alert ─────────────────────────────────────────────────── */\n\n.shared-alert {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: var(--space-4);\n}\n\n@media (max-width: 639px) {\n  .shared-alert {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n}\n\n/* ── AI summary action ───────────────────────────────────────────────────── */\n\n.ai-summary-action {\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n  margin-top: var(--space-2);\n}\n\n.btn--sm {\n  padding: var(--space-1) var(--space-3);\n  font-size: var(--text-sm);\n}\n\n/* ── AI parser preview ───────────────────────────────────────────────────── */\n\n.ai-parser__preview {\n  padding: var(--space-2) var(--space-3);\n  background-color: var(--color-off-white);\n  border-radius: var(--radius-md);\n}\n\n/* ── Validation errors ────────────────────────────────────────────────────── */\n\n.form-errors {\n  margin-top: var(--space-3);\n}\n"
