            "text": "/* ==========================================================================\n   StudyHub — Calendar styles\n   ========================================================================== */\n\n/* ── Toolbar ──────────────────────────────────────────────────────────────── */\n\n.cal-toolbar {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: var(--space-5);\n  flex-wrap: wrap;\n  gap: var(--space-3);\n}\n\n.cal-toolbar__left {\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n}\n\n.cal-toolbar__title {\n  font-family: var(--font-heading);\n  font-weight: var(--weight-extrabold);\n  font-size: var(--text-xl);\n  text-transform: uppercase;\n  min-width: 180px;\n  text-align: center;\n}\n\n.cal-toolbar__right {\n  display: flex;\n  gap: var(--space-1);\n}\n\n.btn--sm {\n  padding: var(--space-1) var(--space-3);\n  font-size: var(--text-xs);\n}\n\n/* ── Month grid ───────────────────────────────────────────────────────────── */\n\n.cal-grid {\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  overflow: hidden;\n}\n\n.cal-grid__header {\n  display: grid;\n  grid-template-columns: 40px repeat(7, 1fr);\n  background-color: var(--color-off-white);\n  border-bottom: var(--border-width) solid var(--color-border);\n}\n\n.cal-grid__wk-header,\n.cal-grid__day-header {\n  padding: var(--space-2) var(--space-1);\n  font-size: var(--text-xs);\n  font-weight: var(--weight-semibold);\n  text-transform: uppercase;\n  text-align: center;\n  color: var(--color-muted);\n}\n\n.cal-grid__wk-header {\n  font-family: var(--font-mono);\n  font-size: 10px;\n  color: var(--color-teal);\n}\n\n.cal-grid__row {\n  display: grid;\n  grid-template-columns: 40px repeat(7, 1fr);\n  border-bottom: var(--border-width) solid var(--color-border);\n}\n\n.cal-grid__row:last-child {\n  border-bottom: none;\n}\n\n.cal-grid__wk {\n  display: flex;\n  align-items: flex-start;\n  justify-content: center;\n  padding-top: var(--space-2);\n  font-family: var(--font-mono);\n  font-size: 10px;\n  font-weight: var(--weight-bold);\n  color: var(--color-teal);\n  background-color: var(--color-teal-light);\n  border-right: var(--border-width) solid var(--color-border);\n}\n\n.cal-grid__cell {\n  min-height: 80px;\n  padding: var(--space-1);\n  border-right: var(--border-width) solid var(--color-border);\n  position: relative;\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.cal-grid__cell:nth-child(8) {\n  /* last column (Sunday) — no right border */\n}\n\n.cal-grid__cell:last-child {\n  border-right: none;\n}\n\n.cal-grid__cell--outside {\n  background-color: var(--color-off-white);\n}\n\n.cal-grid__cell--outside .cal-grid__num {\n  color: var(--color-border);\n}\n\n.cal-grid__cell--today .cal-grid__num {\n  background-color: var(--color-teal);\n  color: var(--color-white);\n  border-radius: var(--radius-full);\n  width: 24px;\n  height: 24px;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.cal-grid__num {\n  font-size: var(--text-sm);\n  font-weight: var(--weight-medium);\n  margin-bottom: 2px;\n  line-height: 1;\n}\n\n/* ── Event chips ──────────────────────────────────────────────────────────── */\n\n.cal-chip {\n  font-size: 10px;\n  line-height: 1.3;\n  padding: 1px 4px;\n  border-radius: var(--radius-sm);\n  background-color: color-mix(in srgb, var(--chip-color) 12%, transparent);\n  color: var(--chip-color);\n  border-left: 2px solid var(--chip-color);\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  cursor: pointer;\n}\n\n.cal-chip:hover {\n  background-color: color-mix(in srgb, var(--chip-color) 20%, transparent);\n}\n\n.cal-chip--sched {\n  font-style: italic;\n  opacity: 0.85;\n}\n\n.cal-more {\n  font-size: 10px;\n  color: var(--color-muted);\n  padding-left: 4px;\n}\n\n/* ── Filters (list view) ──────────────────────────────────────────────────── */\n\n.cal-filters {\n  display: flex;\n  flex-wrap: wrap;\n  gap: var(--space-3);\n  margin-bottom: var(--space-5);\n}\n\n.cal-filters__types,\n.cal-filters__courses {\n  display: flex;\n  gap: var(--space-1);\n  flex-wrap: wrap;\n}\n\n/* ── List view ────────────────────────────────────────────────────────────── */\n\n.cal-list {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-5);\n}\n\n.cal-list-date {\n  font-family: var(--font-heading);\n  font-weight: var(--weight-bold);\n  font-size: var(--text-md);\n  text-transform: uppercase;\n  color: var(--color-muted);\n  margin-bottom: var(--space-2);\n  letter-spacing: 0.03em;\n}\n\n.cal-list-group {\n  display: flex;\n  flex-direction: column;\n}\n\n.cal-list-item {\n  display: flex;\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  overflow: hidden;\n  margin-bottom: var(--space-2);\n  cursor: pointer;\n  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);\n}\n\n.cal-list-item:hover {\n  border-color: var(--color-teal);\n  box-shadow: var(--shadow-sm);\n}\n\n.cal-list-item__bar {\n  width: 4px;\n  flex-shrink: 0;\n}\n\n.cal-list-item__body {\n  padding: var(--space-3) var(--space-4);\n  flex: 1;\n  min-width: 0;\n}\n\n.cal-list-item__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: var(--space-2);\n}\n\n.cal-list-item__title {\n  font-weight: var(--weight-semibold);\n  font-size: var(--text-sm);\n}\n\n.cal-list-item__meta {\n  display: flex;\n  gap: var(--space-3);\n  margin-top: var(--space-1);\n  flex-wrap: wrap;\n}\n\n/* ── Responsive ───────────────────────────────────────────────────────────── */\n\n@media (max-width: 639px) {\n  .cal-grid__cell {\n    min-height: 56px;\n    padding: 2px;\n  }\n\n  .cal-chip {\n    font-size: 9px;\n    padding: 0 2px;\n  }\n\n  .cal-grid__wk {\n    font-size: 9px;\n  }\n\n  .cal-toolbar {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n}\n"
