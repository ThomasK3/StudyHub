            "compression": 0,
            "text": "/* ==========================================================================\n   StudyHub — Course detail styles\n   ========================================================================== */\n\n/* ── Actions bar ──────────────────────────────────────────────────────────── */\n\n.detail__actions {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: var(--space-6);\n}\n\n/* ── Header ───────────────────────────────────────────────────────────────── */\n\n.detail__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  gap: var(--space-4);\n  margin-bottom: var(--space-8);\n}\n\n.detail__code {\n  font-size: var(--text-sm);\n  color: var(--color-teal);\n  font-weight: var(--weight-semibold);\n}\n\n.detail__name {\n  font-size: var(--text-3xl);\n  margin-top: var(--space-1);\n}\n\n.detail__meta {\n  margin-top: var(--space-2);\n  font-size: var(--text-sm);\n}\n\n.detail__meta a {\n  text-decoration: underline;\n  text-underline-offset: 2px;\n}\n\n.badge--credit-lg {\n  width: 44px;\n  height: 44px;\n  font-size: var(--text-lg);\n  flex-shrink: 0;\n}\n\n/* ── Two-column grid ──────────────────────────────────────────────────────── */\n\n.detail__grid {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: var(--space-8);\n}\n\n@media (min-width: 768px) {\n  .detail__grid {\n    grid-template-columns: 1.4fr 1fr;\n  }\n}\n\n.detail__section {\n  margin-bottom: var(--space-8);\n}\n\n/* ── Component cards ──────────────────────────────────────────────────────── */\n\n.comp-card {\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  overflow: hidden;\n  margin-bottom: var(--space-3);\n  display: flex;\n  flex-direction: column;\n}\n\n.comp-card__indicator {\n  height: 3px;\n}\n\n.comp-card__body {\n  padding: var(--space-3) var(--space-4);\n}\n\n.comp-card__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: var(--space-2);\n}\n\n.comp-card__name {\n  font-weight: var(--weight-semibold);\n  font-size: var(--text-md);\n}\n\n.comp-card__weight {\n  font-family: var(--font-mono);\n  font-weight: var(--weight-bold);\n  font-size: var(--text-md);\n  color: var(--color-teal);\n}\n\n.comp-card__points {\n  display: flex;\n  gap: var(--space-3);\n  margin-top: var(--space-1);\n}\n\n.comp-card__desc {\n  margin-top: var(--space-2);\n}\n\n.comp-card__header-right {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2);\n}\n\n.comp-card__status {\n  font-weight: var(--weight-bold);\n  font-size: var(--text-md);\n}\n\n.comp-card__status--pass {\n  color: var(--color-green);\n}\n\n.comp-card__status--fail {\n  color: var(--color-red);\n}\n\n.comp-card--completed {\n  opacity: 0.65;\n}\n\n.comp-card__progress {\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n  margin-top: var(--space-3);\n  padding-top: var(--space-2);\n  border-top: var(--border-width) solid var(--color-border);\n  flex-wrap: wrap;\n}\n\n.comp-card__check-label {\n  display: inline-flex;\n  align-items: center;\n  gap: var(--space-1);\n  cursor: pointer;\n  user-select: none;\n}\n\n.comp-card__earned-label {\n  display: inline-flex;\n  align-items: center;\n  gap: var(--space-1);\n}\n\n.comp-card__earned-label .input--sm {\n  width: 64px;\n}\n\n.comp-card__score {\n  font-size: var(--text-sm);\n  font-weight: var(--weight-semibold);\n  color: var(--color-teal);\n}\n\n.comp-card__bar {\n  height: 4px;\n  background-color: var(--color-off-white);\n}\n\n.comp-card__bar-fill {\n  height: 100%;\n  transition: width var(--transition-base);\n}\n\n/* ── Calculator ──────────────────────────────────────────────────────────── */\n\n.calc-card {\n  border-left: 3px solid var(--color-teal);\n}\n\n.calc-summary {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  flex-wrap: wrap;\n  gap: var(--space-2);\n}\n\n.calc-rows {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-3);\n}\n\n.calc-row {\n  display: flex;\n  gap: var(--space-3);\n  align-items: flex-start;\n}\n\n.calc-row__grade {\n  font-family: var(--font-heading);\n  font-weight: var(--weight-extrabold);\n  font-size: var(--text-xl);\n  min-width: 28px;\n  text-align: center;\n  flex-shrink: 0;\n}\n\n.calc-row__info {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n\n.calc-row__bar {\n  height: 6px;\n  background-color: var(--color-off-white);\n  border-radius: var(--radius-full);\n  overflow: hidden;\n  margin-top: var(--space-1);\n}\n\n.calc-row__bar-fill {\n  height: 100%;\n  border-radius: var(--radius-full);\n  transition: width var(--transition-base);\n}\n\n.calc-row--guaranteed {\n  background-color: var(--color-green-light);\n  padding: var(--space-2) var(--space-3);\n  border-radius: var(--radius-md);\n}\n\n.calc-row--impossible {\n  opacity: 0.5;\n}\n\n/* ── Requirements ─────────────────────────────────────────────────────────── */\n\n.req-list {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-2);\n}\n\n.req-item {\n  display: flex;\n  align-items: flex-start;\n  gap: var(--space-3);\n  padding: var(--space-2) var(--space-3);\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  font-size: var(--text-sm);\n}\n\n.req-item__check {\n  color: var(--color-teal);\n  font-weight: var(--weight-bold);\n  flex-shrink: 0;\n  margin-top: 1px;\n}\n\n/* ── Grading scale ────────────────────────────────────────────────────────── */\n\n.grade-grid {\n  display: flex;\n  gap: var(--space-2);\n  flex-wrap: wrap;\n}\n\n.grade-cell {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  padding: var(--space-3) var(--space-4);\n  min-width: 64px;\n  border-top: 3px solid var(--grade-color);\n}\n\n.grade-cell__grade {\n  font-family: var(--font-heading);\n  font-weight: var(--weight-extrabold);\n  font-size: var(--text-xl);\n  color: var(--grade-color);\n}\n\n.grade-cell__pct {\n  font-size: var(--text-xs);\n  color: var(--color-muted);\n  margin-top: 2px;\n}\n\n/* ── Timeline ─────────────────────────────────────────────────────────────── */\n\n.timeline {\n  position: relative;\n  padding-left: var(--space-6);\n}\n\n.timeline::before {\n  content: '';\n  position: absolute;\n  left: 7px;\n  top: 4px;\n  bottom: 4px;\n  width: 2px;\n  background-color: var(--color-border);\n  border-radius: var(--radius-full);\n}\n\n.timeline-item {\n  position: relative;\n  padding-bottom: var(--space-6);\n}\n\n.timeline-item:last-child {\n  padding-bottom: 0;\n}\n\n.timeline-item--past {\n  opacity: 0.5;\n}\n\n.timeline-item__dot {\n  position: absolute;\n  left: calc(-1 * var(--space-6) + 3px);\n  top: 4px;\n  width: 10px;\n  height: 10px;\n  border-radius: var(--radius-full);\n  border: 2px solid var(--color-white);\n  box-shadow: 0 0 0 2px var(--color-border);\n}\n\n.timeline-item__content {\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  padding: var(--space-3) var(--space-4);\n}\n\n.timeline-item__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: var(--space-2);\n  margin-bottom: var(--space-1);\n}\n\n.timeline-item__title {\n  font-weight: var(--weight-semibold);\n  font-size: var(--text-sm);\n}\n\n.timeline-item__date {\n  color: var(--color-muted);\n}\n\n.timeline-item__badges {\n  display: flex;\n  gap: var(--space-2);\n  margin-top: var(--space-2);\n}\n\n/* ── AI Summary ──────────────────────────────────────────────────────────── */\n\n.detail__ai-summary {\n  position: relative;\n  border-left: 3px solid var(--color-teal);\n}\n\n.detail__ai-summary .tag {\n  position: absolute;\n  top: var(--space-2);\n  right: var(--space-3);\n}\n\n.detail__description-section {\n  margin-bottom: var(--space-6);\n}\n\n/* ── Learning outcomes ───────────────────────────────────────────────────── */\n\n.detail__outcomes-list {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-1);\n  padding-left: var(--space-4);\n  list-style: disc;\n  color: var(--color-muted);\n}\n\n.detail__outcomes-list li {\n  color: var(--color-text);\n}\n\n/* ── Weekly topics ───────────────────────────────────────────────────────── */\n\n.weekly-topics {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-1);\n}\n\n.weekly-topic {\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n  padding: var(--space-2) var(--space-3);\n  border-radius: var(--radius-md);\n  border: var(--border-width) solid transparent;\n}\n\n.weekly-topic--current {\n  background-color: var(--color-teal-light);\n  border-color: var(--color-teal);\n}\n\n.weekly-topic__week {\n  width: 24px;\n  text-align: right;\n  flex-shrink: 0;\n  font-size: var(--text-sm);\n  color: var(--color-muted);\n}\n\n/* ── Workload bars ───────────────────────────────────────────────────────── */\n\n.workload-bar {\n  margin-bottom: var(--space-3);\n}\n\n.workload-bar__label {\n  display: flex;\n  justify-content: space-between;\n  margin-bottom: var(--space-1);\n}\n\n.workload-bar__track {\n  height: 8px;\n  background-color: var(--color-off-white);\n  border-radius: var(--radius-full);\n  overflow: hidden;\n}\n\n.workload-bar__fill {\n  height: 100%;\n  border-radius: var(--radius-full);\n  transition: width var(--transition-base);\n}\n\n/* ── Schedule table ──────────────────────────────────────────────────────── */\n\n.detail__schedule-wrap {\n  overflow-x: auto;\n}\n\n.detail__schedule {\n  width: 100%;\n  border-collapse: collapse;\n  font-size: var(--text-sm);\n}\n\n.detail__schedule th,\n.detail__schedule td {\n  padding: var(--space-2) var(--space-3);\n  text-align: left;\n  border-bottom: var(--border-width) solid var(--color-border);\n  white-space: nowrap;\n}\n\n.detail__schedule th {\n  font-weight: var(--weight-semibold);\n  color: var(--color-muted);\n  font-size: var(--text-xs);\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n}\n\n.detail__schedule--interactive .schedule-row {\n  cursor: pointer;\n  transition: background-color var(--transition-base), opacity var(--transition-base);\n}\n\n.detail__schedule--interactive .schedule-row:hover {\n  background-color: var(--color-off-white);\n  opacity: 1 !important;\n}\n\n.detail__schedule--interactive .schedule-row--selected {\n  background-color: var(--color-teal-light);\n  opacity: 1 !important;\n}\n\n.detail__schedule--interactive .schedule-row--selected td {\n  color: var(--color-text);\n}\n\n/* ── Score pass/fail colors ───────────────────────────────────────────────── */\n\n.comp-card__score--pass {\n  color: var(--color-green);\n}\n\n.comp-card__score--fail {\n  color: var(--color-red);\n}\n\n/* ── Literature ──────────────────────────────────────────────────────────── */\n\n.detail__lit-list {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-1);\n  padding-left: var(--space-4);\n  list-style: disc;\n}\n\n/* ── Grade cell label ────────────────────────────────────────────────────── */\n\n.grade-cell__label {\n  font-size: var(--text-xs);\n  color: var(--color-muted);\n}\n"
