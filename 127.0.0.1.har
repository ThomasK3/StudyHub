          "content": {
            "size": 14312,
            "mimeType": "text/css",
            "compression": 0,
            "text": "/* ==========================================================================\n   StudyHub — Planner & AI styles\n   ========================================================================== */\n\n.planner {\n  max-width: 1200px;\n}\n\n/* ── Hero calendar (full width) ─────────────────────────────────────────── */\n\n.planner__hero {\n  margin-bottom: var(--space-6);\n}\n\n/* ── Course cards grid ──────────────────────────────────────────────────── */\n\n.planner__courses-section {\n  margin-bottom: var(--space-6);\n}\n\n.planner-courses-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));\n  gap: var(--space-3);\n}\n\n.planner-course {\n  display: flex;\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  background-color: var(--color-white);\n  overflow: hidden;\n  transition: box-shadow var(--transition-fast);\n}\n\n.planner-course:hover {\n  box-shadow: var(--shadow-sm);\n}\n\n.planner-course__color-bar {\n  width: 4px;\n  flex-shrink: 0;\n  background-color: var(--course-color);\n}\n\n.planner-course__body {\n  padding: var(--space-2) var(--space-3);\n  flex: 1;\n  min-width: 0;\n}\n\n.planner-course__top {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: var(--space-2);\n  margin-bottom: var(--space-1);\n}\n\n.planner-course__name {\n  font-size: var(--text-sm);\n  font-weight: 600;\n  line-height: 1.3;\n  margin-bottom: var(--space-1);\n  overflow: hidden;\n  text-overflow: ellipsis;\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n}\n\n.planner-course__meta {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2);\n  flex-wrap: wrap;\n}\n\n.planner-course__status {\n  font-size: var(--text-sm);\n  font-weight: 700;\n  width: 20px;\n  height: 20px;\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  border-radius: var(--radius-full);\n  flex-shrink: 0;\n}\n\n.planner-course__status--ok {\n  background-color: var(--color-green-light);\n  color: var(--color-green);\n}\n\n.planner-course__status--missing {\n  background-color: var(--color-amber-light);\n  color: var(--color-amber);\n}\n\n.planner-course__status--none {\n  background-color: var(--color-off-white);\n  color: var(--color-muted);\n}\n\n.planner-course--incomplete {\n  border-color: color-mix(in srgb, var(--color-amber) 30%, var(--color-border));\n}\n\n/* ── Rules section ─────────────────────────────────────────────────────── */\n\n.planner__rules {\n  margin-bottom: var(--space-6);\n}\n\n.planner__rules-grid {\n  display: flex;\n  flex-wrap: wrap;\n  gap: var(--space-4);\n  align-items: end;\n}\n\n.planner__rule {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-1);\n}\n\n.planner__rule .input--sm {\n  width: 80px;\n}\n\n.planner__rule-toggle {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2);\n  cursor: pointer;\n}\n\n.planner__blocked-row {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2);\n  margin-top: var(--space-2);\n  flex-wrap: wrap;\n}\n\n.planner__blocked-row .input--sm {\n  width: auto;\n  min-width: 0;\n}\n\n.planner__blocked-row .input--sm[type=\"date\"] {\n  width: 140px;\n}\n\n.planner__blocked-row .input--sm[type=\"text\"] {\n  flex: 1;\n  min-width: 100px;\n}\n\n.planner__priority-chips {\n  display: flex;\n  flex-wrap: wrap;\n  gap: var(--space-2);\n  margin-top: var(--space-2);\n}\n\n.planner__prio-chip {\n  appearance: none;\n  border: var(--border-width) solid var(--color-border);\n  background-color: var(--color-off-white);\n  color: var(--color-text);\n  border-radius: var(--radius-md);\n  padding: var(--space-1) var(--space-3);\n  font-size: var(--text-sm);\n  font-family: var(--font-mono);\n  cursor: pointer;\n  user-select: none;\n  transition: all var(--transition-fast);\n}\n\n.planner__prio-chip:hover {\n  border-color: var(--color-teal);\n}\n\n.planner__prio-chip--active {\n  background-color: var(--color-teal);\n  border-color: var(--color-teal);\n  color: white;\n  font-weight: 600;\n}\n\n.planner__schedule-actions {\n  display: flex;\n  gap: var(--space-3);\n  flex-wrap: wrap;\n}\n\n.btn--danger {\n  color: var(--color-red);\n  border-color: color-mix(in srgb, var(--color-red) 30%, var(--color-border));\n}\n\n.btn--danger:hover {\n  background-color: var(--color-red-light);\n}\n\n/* ── Success alert ─────────────────────────────────────────────────────── */\n\n.alert--success {\n  background-color: var(--color-green-light);\n  color: var(--color-green);\n  border: var(--border-width) solid color-mix(in srgb, var(--color-green) 20%, transparent);\n  padding: var(--space-3) var(--space-4);\n  border-radius: var(--radius-md);\n  font-size: var(--text-sm);\n}\n\n/* ── Two-column bottom ──────────────────────────────────────────────────── */\n\n.planner__bottom {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: var(--space-6);\n  align-items: start;\n}\n\n@media (max-width: 768px) {\n  .planner__bottom {\n    grid-template-columns: 1fr;\n  }\n}\n\n.planner__bottom-left,\n.planner__bottom-right {\n  min-width: 0;\n}\n\n/* ── Exam overview cards (legacy) ───────────────────────────────────────── */\n\n.planner__exams {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-2);\n}\n\n.planner__exam-card {\n  display: flex;\n  align-items: center;\n  gap: var(--space-4);\n  padding: var(--space-2) var(--space-3);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  background-color: var(--color-off-white);\n  flex-wrap: wrap;\n}\n\n.planner__exam-date {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2);\n}\n\n/* ── Advice card ────────────────────────────────────────────────────────── */\n\n.planner__advice {\n  border-left: 3px solid var(--color-teal);\n  padding: var(--space-4);\n  font-size: var(--text-sm);\n  line-height: 1.6;\n}\n\n/* ── Plan result cards ──────────────────────────────────────────────────── */\n\n.planner__plan-list {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-3);\n}\n\n.planner__plan-card {\n  display: flex;\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  overflow: hidden;\n}\n\n.planner__plan-bar {\n  width: 4px;\n  flex-shrink: 0;\n}\n\n.planner__plan-body {\n  padding: var(--space-3);\n  flex: 1;\n}\n\n.planner__plan-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  gap: var(--space-3);\n  margin-bottom: var(--space-2);\n  flex-wrap: wrap;\n}\n\n/* ── Planner import & exam calendar ────────────────────────────────────── */\n\n.planner__import-actions {\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n  flex-wrap: wrap;\n}\n\n.planner-cal {\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-lg);\n  overflow: hidden;\n  background-color: var(--color-white);\n}\n\n.planner-cal__header {\n  display: grid;\n  grid-template-columns: repeat(7, minmax(0, 1fr));\n  background-color: var(--color-off-white);\n  border-bottom: var(--border-width) solid var(--color-border);\n}\n\n.planner-cal__day-header {\n  padding: var(--space-2);\n  min-width: 0;\n  font-size: var(--text-sm);\n  font-weight: 600;\n  text-transform: uppercase;\n  letter-spacing: 0.02em;\n  color: var(--color-muted);\n}\n\n.planner-cal__row {\n  display: grid;\n  grid-template-columns: repeat(7, minmax(0, 1fr));\n}\n\n.planner-cal__cell {\n  min-height: 92px;\n  min-width: 0;\n  padding: var(--space-2);\n  border-right: var(--border-width) solid var(--color-border);\n  border-bottom: var(--border-width) solid var(--color-border);\n  background-color: var(--color-white);\n  overflow: visible;\n}\n\n.planner-cal__row .planner-cal__cell:last-child {\n  border-right: none;\n}\n\n.planner-cal__cell--outside {\n  background-color: color-mix(in srgb, var(--color-off-white) 70%, var(--color-white));\n}\n\n.planner-cal__cell--today {\n  outline: 2px solid color-mix(in srgb, var(--color-teal) 40%, transparent);\n  outline-offset: -2px;\n}\n\n.planner-cal__cell--ai-highlight {\n  background-color: color-mix(in srgb, var(--color-teal) 5%, var(--color-white));\n}\n\n.planner-cal__cell-top {\n  display: flex;\n  align-items: baseline;\n  justify-content: space-between;\n  gap: var(--space-2);\n  margin-bottom: var(--space-2);\n}\n\n.planner-cal__num {\n  font-weight: 700;\n}\n\n.planner-cal__wk {\n  font-size: var(--text-xs);\n  color: var(--color-muted);\n}\n\n.planner-cal__chips {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-2);\n}\n\n/* ── Chips ──────────────────────────────────────────────────────────────── */\n\n.planner-chip {\n  appearance: none;\n  border: var(--border-width) solid color-mix(in srgb, var(--chip-color) 40%, var(--color-border));\n  background-color: color-mix(in srgb, var(--chip-color) 10%, var(--color-white));\n  color: color-mix(in srgb, var(--chip-color) 80%, black);\n  border-radius: var(--radius-md);\n  padding: 5px 7px;\n  font-size: var(--text-xs);\n  line-height: 1.2;\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n  cursor: pointer;\n  user-select: none;\n  width: 100%;\n  text-align: left;\n  white-space: normal;\n}\n\n.planner-chip:hover {\n  border-color: color-mix(in srgb, var(--chip-color) 70%, var(--color-border));\n  background-color: color-mix(in srgb, var(--chip-color) 14%, var(--color-white));\n}\n\n.planner-chip--selected {\n  background-color: var(--chip-color);\n  border-color: var(--chip-color);\n  color: white;\n}\n\n.planner-chip--dimmed {\n  opacity: 0.35;\n  filter: grayscale(0.2);\n}\n\n.planner-chip--ai-suggested {\n  border-color: color-mix(in srgb, var(--chip-color) 60%, var(--color-teal));\n  background-color: color-mix(in srgb, var(--chip-color) 12%, color-mix(in srgb, var(--color-teal) 8%, var(--color-white)));\n  box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-teal) 20%, transparent);\n}\n\n.planner-chip--ai-only {\n  cursor: default;\n  border-style: dashed;\n  border-color: color-mix(in srgb, var(--chip-color) 40%, var(--color-teal));\n  background-color: color-mix(in srgb, var(--color-teal) 6%, var(--color-white));\n}\n\n.planner-chip__code {\n  font-weight: 700;\n}\n\n.planner-chip__time {\n  font-variant-numeric: tabular-nums;\n  opacity: 0.9;\n}\n\n.planner-chip__row {\n  display: flex;\n  align-items: baseline;\n  justify-content: space-between;\n  gap: var(--space-2);\n  width: 100%;\n}\n\n.planner-chip__right {\n  display: inline-flex;\n  align-items: baseline;\n  gap: 4px;\n  flex-shrink: 0;\n}\n\n.planner-chip__meta {\n  font-size: 10px;\n  opacity: 0.75;\n  line-height: 1.2;\n}\n\n.planner-chip__type {\n  font-weight: 700;\n  opacity: 0.95;\n}\n\n.planner-chip__ai-badge {\n  color: var(--color-teal);\n  font-size: var(--text-xs);\n  font-weight: 700;\n}\n\n.planner-chip--selected .planner-chip__ai-badge {\n  color: white;\n}\n\n.planner-chip--credit {\n  border-style: dashed;\n}\n\n.planner-chip--credit.planner-chip--selected {\n  box-shadow: inset 0 0 0 2px color-mix(in srgb, white 35%, transparent);\n}\n\n.planner-chip--exam .planner-chip__type {\n  letter-spacing: 0.02em;\n}\n\n.planner-chip--credit .planner-chip__type {\n  letter-spacing: 0.02em;\n}\n\n/* ── Legend ─────────────────────────────────────────────────────────────── */\n\n.planner-legend {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-2);\n}\n\n.planner-legend__item {\n  padding: var(--space-2) var(--space-3);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  background-color: var(--color-off-white);\n}\n\n.planner-legend__top {\n  display: flex;\n  align-items: flex-start;\n  justify-content: space-between;\n  gap: var(--space-3);\n  flex-wrap: wrap;\n}\n\n.planner-legend__title {\n  display: flex;\n  align-items: baseline;\n  gap: var(--space-2);\n  flex-wrap: wrap;\n}\n\n.planner-legend__badges {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2);\n  flex-wrap: wrap;\n}\n\n.planner-legend__meta {\n  margin-top: var(--space-1);\n}\n\n/* ── Spinner ────────────────────────────────────────────────────────────── */\n\n.spinner {\n  display: inline-block;\n  width: 14px;\n  height: 14px;\n  border: 2px solid rgba(255, 255, 255, 0.3);\n  border-top-color: currentColor;\n  border-radius: 50%;\n  animation: spin 0.6s linear infinite;\n}\n\n@keyframes spin {\n  to { transform: rotate(360deg); }\n}\n\n/* ── API key dialog ─────────────────────────────────────────────────────── */\n\n.ai-key-overlay {\n  position: fixed;\n  inset: 0;\n  background-color: var(--color-overlay);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 1000;\n  padding: var(--space-4);\n}\n\n.ai-key-dialog {\n  background-color: var(--color-white);\n  border-radius: var(--radius-lg);\n  padding: var(--space-6);\n  max-width: 420px;\n  width: 100%;\n  box-shadow: var(--shadow-lg);\n}\n\n.ai-key-dialog__actions {\n  display: flex;\n  gap: var(--space-3);\n}\n\n/* ── AI parser section ──────────────────────────────────────────────────── */\n\n.ai-parser {\n  border-left: 3px solid var(--color-blue);\n}\n\n.ai-parser__actions {\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n}\n"
