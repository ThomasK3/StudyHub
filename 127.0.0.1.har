            "text": "/* ==========================================================================\n   StudyHub — Dashboard styles\n   ========================================================================== */\n\n/* ── Status bar ──────────────────────────────────────────────────────────── */\n\n.dashboard__status {\n  display: flex;\n  justify-content: flex-end;\n  margin-bottom: var(--space-2);\n}\n\n.badge--online {\n  background-color: var(--color-teal-light);\n  color: var(--color-teal);\n  font-size: var(--text-xs);\n  font-weight: var(--weight-semibold);\n}\n\n/* ── Stats row ────────────────────────────────────────────────────────────── */\n\n.stats-row {\n  display: flex;\n  gap: var(--space-4);\n  flex-wrap: wrap;\n}\n\n.stat-card {\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  padding: var(--space-4) var(--space-5);\n  display: flex;\n  flex-direction: column;\n  min-width: 120px;\n  flex: 1;\n}\n\n.stat-card--wide {\n  flex: 2;\n}\n\n.stat-card__value {\n  font-family: var(--font-heading);\n  font-weight: var(--weight-extrabold);\n  font-size: var(--text-2xl);\n  color: var(--color-teal);\n  text-transform: uppercase;\n  line-height: 1.2;\n}\n\n.stat-card__label {\n  font-size: var(--text-xs);\n  color: var(--color-muted);\n  margin-top: var(--space-1);\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n}\n\n/* ── Countdown row ─────────────────────────────────────────────────────── */\n\n.countdown-row {\n  display: flex;\n  gap: var(--space-4);\n  margin-top: var(--space-6);\n  flex-wrap: wrap;\n}\n\n.countdown-box {\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  padding: var(--space-4) var(--space-5);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  text-align: center;\n  flex: 1;\n  min-width: 130px;\n}\n\n.countdown-box__value {\n  font-family: var(--font-heading);\n  font-weight: var(--weight-extrabold);\n  font-size: 36px;\n  line-height: 1;\n}\n\n.countdown-box__label {\n  font-size: var(--text-sm);\n  color: var(--color-muted);\n  margin-top: var(--space-2);\n}\n\n.countdown-box__sublabel {\n  font-size: var(--text-xs);\n  color: var(--color-teal);\n  margin-top: var(--space-1);\n}\n\n.countdown-box__unit {\n  font-size: var(--text-xs);\n  color: var(--color-muted);\n  margin-top: 2px;\n}\n\n@media (max-width: 480px) {\n  .countdown-row {\n    flex-direction: column;\n  }\n}\n\n/* ── Today section ─────────────────────────────────────────────────────── */\n\n.today-section {\n  margin-bottom: var(--space-2);\n}\n\n.today-classes {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-2);\n  margin-bottom: var(--space-3);\n}\n\n.today-item {\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n  padding: var(--space-2) var(--space-3);\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  font-size: var(--text-sm);\n}\n\n.today-item__time {\n  font-weight: var(--weight-semibold);\n  color: var(--color-teal);\n  flex-shrink: 0;\n}\n\n.today-item__desc {\n  flex: 1;\n}\n\n.today-item__room {\n  font-size: var(--text-xs);\n  flex-shrink: 0;\n}\n\n.today-alerts {\n  display: flex;\n  flex-direction: column;\n  gap: var(--space-2);\n}\n\n.today-alert {\n  display: flex;\n  align-items: center;\n  gap: var(--space-3);\n  padding: var(--space-2) var(--space-3);\n  border-radius: var(--radius-md);\n  font-size: var(--text-sm);\n}\n\n.today-alert--red {\n  background-color: var(--color-red-light);\n  border: var(--border-width) solid color-mix(in srgb, var(--color-red) 20%, transparent);\n  color: var(--color-red);\n}\n\n.today-alert--amber {\n  background-color: var(--color-amber-light);\n  border: var(--border-width) solid color-mix(in srgb, var(--color-amber) 20%, transparent);\n  color: var(--color-warning-text);\n}\n\n.today-alert__when {\n  font-weight: var(--weight-bold);\n  flex-shrink: 0;\n}\n\n.today-alert__title {\n  flex: 1;\n}\n\n.today-alert__course {\n  font-size: var(--text-xs);\n  flex-shrink: 0;\n}\n\n/* ── Event strip ──────────────────────────────────────────────────────────── */\n\n.event-strip {\n  display: flex;\n  gap: var(--space-4);\n  overflow-x: auto;\n  padding-bottom: var(--space-2);\n  -webkit-overflow-scrolling: touch;\n}\n\n.event-strip::-webkit-scrollbar {\n  height: 4px;\n}\n\n.event-strip::-webkit-scrollbar-thumb {\n  background: var(--color-border);\n  border-radius: var(--radius-full);\n}\n\n.event-card {\n  display: flex;\n  gap: var(--space-3);\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  padding: var(--space-3);\n  min-width: 220px;\n  flex-shrink: 0;\n  cursor: pointer;\n  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);\n}\n\n.event-card:hover {\n  border-color: var(--color-teal);\n  box-shadow: var(--shadow-sm);\n}\n\n.event-card__date {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  background-color: var(--color-teal);\n  color: var(--color-white);\n  border-radius: var(--radius-md);\n  min-width: 48px;\n  padding: var(--space-2);\n}\n\n.event-card__day {\n  font-family: var(--font-heading);\n  font-weight: var(--weight-extrabold);\n  font-size: var(--text-xl);\n  line-height: 1;\n}\n\n.event-card__month {\n  font-size: var(--text-xs);\n  text-transform: uppercase;\n  letter-spacing: 0.06em;\n  margin-top: 2px;\n}\n\n.event-card__body {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n  min-width: 0;\n}\n\n.event-card__title {\n  font-weight: var(--weight-semibold);\n  font-size: var(--text-sm);\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.event-card__course {\n  font-size: var(--text-xs);\n  color: var(--color-teal);\n}\n\n.event-card__meta {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2);\n  margin-top: var(--space-1);\n}\n\n/* ── Event type badges ────────────────────────────────────────────────────── */\n\n.badge--exam        { background-color: var(--color-red-light);   color: var(--color-red); }\n.badge--test        { background-color: var(--color-amber-light); color: var(--color-warning-text); }\n.badge--deadline    { background-color: var(--color-blue-light);  color: var(--color-info-text); }\n.badge--presentation { background-color: color-mix(in srgb, var(--color-purple) 8%, transparent); color: var(--color-purple); }\n.badge--other       { background-color: var(--color-off-white);   color: var(--color-muted); }\n.badge--rel         { background-color: var(--color-teal-light);  color: var(--color-teal-dark); }\n.badge--ok          { background-color: var(--color-green-light); color: var(--color-green); }\n\n/* ── Course grid ──────────────────────────────────────────────────────────── */\n\n.course-grid {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: var(--space-4);\n}\n\n@media (min-width: 640px) {\n  .course-grid { grid-template-columns: repeat(2, 1fr); }\n}\n\n@media (min-width: 1024px) {\n  .course-grid { grid-template-columns: repeat(3, 1fr); }\n}\n\n.course-card {\n  background-color: var(--color-white);\n  border: var(--border-width) solid var(--color-border);\n  border-radius: var(--radius-md);\n  overflow: hidden;\n  cursor: pointer;\n  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);\n}\n\n.course-card:hover {\n  border-color: var(--color-teal);\n  box-shadow: var(--shadow-md);\n}\n\n.course-card__bar {\n  height: 4px;\n}\n\n.course-card__content {\n  padding: var(--space-4);\n}\n\n.course-card__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  gap: var(--space-3);\n}\n\n.course-card__code {\n  font-size: var(--text-xs);\n  color: var(--color-teal);\n  font-weight: var(--weight-semibold);\n}\n\n.course-card__name {\n  font-family: var(--font-heading);\n  font-weight: var(--weight-bold);\n  font-size: var(--text-md);\n  text-transform: uppercase;\n  margin-top: 2px;\n  line-height: 1.3;\n}\n\n.course-card__lecturer {\n  margin-top: var(--space-2);\n}\n\n/* Components bar */\n.comp-bar {\n  display: flex;\n  height: 6px;\n  border-radius: var(--radius-full);\n  overflow: hidden;\n  margin-top: var(--space-3);\n  background-color: var(--color-off-white);\n}\n\n.comp-bar__segment {\n  height: 100%;\n  transition: width var(--transition-base);\n}\n\n/* Progress mini display */\n.course-card__progress {\n  margin-top: var(--space-2);\n}\n\n/* Next event in card */\n.course-card__event {\n  display: flex;\n  align-items: center;\n  gap: var(--space-2);\n  margin-top: var(--space-3);\n  padding-top: var(--space-3);\n  border-top: var(--border-width) solid var(--color-border);\n  flex-wrap: wrap;\n}\n\n/* ── Empty state ──────────────────────────────────────────────────────────── */\n\n/* ── Study plan info box ──────────────────────────────────────────────────── */\n\n.plan-info-box {\n  background-color: var(--color-teal-light);\n  border: var(--border-width) solid color-mix(in srgb, var(--color-teal) 20%, transparent);\n  border-radius: var(--radius-md);\n  padding: var(--space-3) var(--space-4);\n  margin-bottom: var(--space-4);\n}\n\n.plan-info-box__header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: var(--space-3);\n}\n\n.plan-info-box__title {\n  font-weight: var(--weight-semibold);\n  font-size: var(--text-sm);\n  color: var(--color-teal-dark);\n}\n\n/* ── Empty state ──────────────────────────────────────────────────────────── */\n\n.empty-state {\n  border: 2px dashed var(--color-border);\n  border-radius: var(--radius-lg);\n  padding: var(--space-10);\n  text-align: center;\n  color: var(--color-muted);\n}\n"
          },
