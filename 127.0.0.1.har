          "content": {
            "size": 7556,
            "mimeType": "text/css",
            "compression": 0,
            "text": "/* ==========================================================================\n   VŠE StudyHub — Design Tokens\n   Based on FIS VŠE visual identity\n   ========================================================================== */\n\n:root {\n  /* ── Colors ─────────────────────────────────────────────────────────── */\n\n  /* Primary — Teal (FIS brand) */\n  --color-teal:          #00957d;\n  --color-teal-dark:     #007a68;\n  --color-teal-deep:     #003d35;\n  --color-teal-light:    rgba(0, 149, 125, 0.08);\n  --color-teal-medium:   rgba(0, 149, 125, 0.15);\n\n  /* Secondary — Blue (FIS accent) */\n  --color-blue:          #009ee0;\n  --color-blue-light:    rgba(0, 158, 224, 0.08);\n\n  /* Neutral */\n  --color-white:         #ffffff;\n  --color-off-white:     #f4f7f6;\n  --color-border:        #dde8e5;\n  --color-muted:         #5a7060;\n  --color-text:          #1a1a1a;\n  --color-dark-nav:      #1e2e28;\n  --color-navy:          #1a2d3a;\n\n  /* Semantic */\n  --color-red:           #dc2626;\n  --color-red-light:     rgba(220, 38, 38, 0.07);\n  --color-amber:         #d97706;\n  --color-amber-light:   #fef3c7;\n  --color-green:         #166534;\n  --color-green-light:   #dcfce7;\n  --color-purple:        #7c3aed;\n\n  /* Event type colors */\n  --color-event-exam:    #dc2626;\n  --color-event-test:    #d97706;\n  --color-event-deadline: #009ee0;\n  --color-event-presentation: #7c3aed;\n\n  /* Credit badge colors (by credit count) */\n  --color-credit-3:      #009ee0;\n  --color-credit-4:      #7c3aed;\n  --color-credit-5:      #d97706;\n  --color-credit-6:      #00957d;\n  --color-credit-7:      #dc2626;\n\n  /* ── Typography ─────────────────────────────────────────────────────── */\n\n  --font-heading:    'Barlow Condensed', sans-serif;\n  --font-body:       'Barlow', sans-serif;\n  --font-mono:       'JetBrains Mono', monospace;\n\n  --text-xs:         11px;\n  --text-sm:         12px;\n  --text-base:       13px;\n  --text-md:         14px;\n  --text-lg:         18px;\n  --text-xl:         22px;\n  --text-2xl:        28px;\n  --text-3xl:        36px;\n\n  --weight-regular:  400;\n  --weight-medium:   500;\n  --weight-semibold: 600;\n  --weight-bold:     700;\n  --weight-extrabold: 800;\n\n  /* ── Spacing ────────────────────────────────────────────────────────── */\n\n  --space-1:         4px;\n  --space-2:         8px;\n  --space-3:         12px;\n  --space-4:         16px;\n  --space-5:         20px;\n  --space-6:         24px;\n  --space-8:         32px;\n  --space-10:        40px;\n  --space-12:        48px;\n\n  /* ── Borders & Radius ───────────────────────────────────────────────── */\n\n  --radius-sm:       2px;\n  --radius-md:       3px;\n  --radius-lg:       6px;\n  --radius-full:     9999px;\n  --border-width:    1px;\n\n  /* ── Shadows ────────────────────────────────────────────────────────── */\n\n  --shadow-sm:       0 1px 2px rgba(0, 0, 0, 0.05);\n  --shadow-md:       0 4px 6px rgba(0, 0, 0, 0.07);\n  --shadow-lg:       0 10px 15px rgba(0, 0, 0, 0.1);\n\n  /* ── Layout ─────────────────────────────────────────────────────────── */\n\n  --max-width:       1100px;\n  --sidebar-width:   280px;\n  --navbar-height:   56px;\n  --topbar-height:   32px;\n\n  /* ── Breakpoints (for reference, use in @media) ─────────────────────── */\n  /* --bp-sm:  640px   */\n  /* --bp-md:  768px   */\n  /* --bp-lg:  1024px  */\n  /* --bp-xl:  1280px  */\n\n  /* ── Transitions ────────────────────────────────────────────────────── */\n\n  --transition-fast:   0.12s ease;\n  --transition-base:   0.2s ease;\n  --transition-slow:   0.3s ease;\n\n  /* ── Derived semantic colors ──────────────────────────────────────────── */\n\n  --color-info-text:         #0369a1;\n  --color-warning-text:      #92400e;\n  --color-overlay:           rgba(0, 0, 0, 0.4);\n  --color-topbar-text:       rgba(255, 255, 255, 0.7);\n  --color-footer-text:       rgba(255, 255, 255, 0.8);\n  --color-footer-copy:       rgba(255, 255, 255, 0.5);\n\n  /* Component type colors */\n  --color-comp-exam:         var(--color-red);\n  --color-comp-test:         var(--color-amber);\n  --color-comp-project:      var(--color-blue);\n  --color-comp-homework:     var(--color-purple);\n  --color-comp-seminar:      var(--color-teal);\n  --color-comp-attendance:   var(--color-green);\n  --color-comp-other:        var(--color-muted);\n\n  /* Grade colors */\n  --color-grade-1:           var(--color-green);\n  --color-grade-2:           var(--color-teal);\n  --color-grade-3:           var(--color-amber);\n  --color-grade-4:           var(--color-red);\n\n  /* Workload colors */\n  --color-workload-lectures:  var(--color-teal);\n  --color-workload-seminars:  var(--color-blue);\n  --color-workload-project:   var(--color-purple);\n  --color-workload-testprep:  var(--color-amber);\n  --color-workload-examprep:  var(--color-red);\n\n  /* Priority colors */\n  --color-priority-high:     var(--color-red);\n  --color-priority-high-bg:  var(--color-red-light);\n  --color-priority-medium:   var(--color-amber);\n  --color-priority-medium-bg: var(--color-amber-light);\n  --color-priority-low:      var(--color-teal);\n  --color-priority-low-bg:   var(--color-teal-light);\n}\n\n/* ── Dark theme ──────────────────────────────────────────────────────────── */\n\n[data-theme=\"dark\"] {\n  --color-teal:            #00b894;\n  --color-teal-dark:       #00957d;\n  --color-teal-deep:       #001a15;\n  --color-teal-light:      rgba(0, 184, 148, 0.1);\n  --color-teal-medium:     rgba(0, 184, 148, 0.18);\n  --color-blue:            #4fc3f7;\n  --color-blue-light:      rgba(79, 195, 247, 0.1);\n  --color-white:           #1a1f1e;\n  --color-off-white:       #0f1413;\n  --color-border:          #2a3530;\n  --color-muted:           #8a9a8f;\n  --color-text:            #e8ede9;\n  --color-dark-nav:        #0a0f0d;\n  --color-navy:            #0d1b24;\n  --color-red:             #f87171;\n  --color-red-light:       rgba(248, 113, 113, 0.12);\n  --color-amber:           #fbbf24;\n  --color-amber-light:     rgba(251, 191, 36, 0.12);\n  --color-green:           #34d399;\n  --color-green-light:     rgba(52, 211, 153, 0.12);\n  --color-purple:          #a78bfa;\n\n  --color-info-text:       #4fc3f7;\n  --color-warning-text:    #fbbf24;\n  --color-topbar-text:     rgba(255, 255, 255, 0.6);\n  --color-footer-text:     rgba(255, 255, 255, 0.7);\n  --color-footer-copy:     rgba(255, 255, 255, 0.4);\n  --color-overlay:         rgba(0, 0, 0, 0.6);\n\n  --shadow-sm:             0 1px 2px rgba(0, 0, 0, 0.2);\n  --shadow-md:             0 4px 6px rgba(0, 0, 0, 0.3);\n  --shadow-lg:             0 10px 15px rgba(0, 0, 0, 0.4);\n}\n"
          },
