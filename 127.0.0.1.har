            "text": "[{\"id\":\"0f2620eb-4c39-45b3-bb23-701f0b895428\",\"code\":\"4IT115\",\"semester\":\"LS 2025/26\",\"data\":{\"code\": \"4IT115\", \"name\": \"Softwarové inženýrství\", \"group\": \"povinny\", \"credits\": 6, \"insisUrl\": \"https://insis.vse.cz/auth/katalog/syllabus.pl?zpet=/auth/katalog/index.pl?vzorek=4IT,Dohledat=Dohledat,fakulta=31140,obdobi=381,obdobi_fak=1187,jak=dle_jmena;predmet=215361;lang=cz\", \"lecturer\": \"Ing. Filip Vencovský, Ph.D.\", \"schedule\": [{\"day\": \"Po\", \"room\": \"SB 103\", \"time\": \"18:00-19:30\", \"type\": \"seminar\", \"teacher\": \"Ing. Jakub Salavec\", \"capacity\": 26, \"frequency\": \"každý\"}, {\"day\": \"Út\", \"room\": \"SB 104\", \"time\": \"12:45-14:15\", \"type\": \"seminar\", \"teacher\": \"Ing. Filip Vencovský, Ph.D.\", \"capacity\": 26, \"frequency\": \"každý\"}, {\"day\": \"Út\", \"room\": \"SB 107\", \"time\": \"14:30-16:00\", \"type\": \"seminar\", \"teacher\": \"Ing. Filip Vencovský, Ph.D.\", \"capacity\": 26, \"frequency\": \"každý\"}, {\"day\": \"Út\", \"room\": \"SB 208\", \"time\": \"18:00-19:30\", \"type\": \"seminar\", \"teacher\": \"Bc. Jan Veverka\", \"capacity\": 26, \"frequency\": \"každý\"}, {\"day\": \"St\", \"room\": \"NB B\", \"time\": \"11:00-12:30\", \"type\": \"lecture\", \"teacher\": \"Ing. Filip Vencovský, Ph.D.\", \"capacity\": 104, \"frequency\": \"každý\"}], \"semester\": \"LS 2025/26\", \"workload\": {\"total\": 156, \"project\": 51, \"examPrep\": 20, \"lectures\": 13, \"seminars\": 26, \"testPrep\": 20}, \"aiSummary\": \"\", \"components\": [{\"name\": \"Aktivita na cvičeních\", \"type\": \"attendance\", \"weight\": 10, \"maxScore\": null, \"description\": \"\", \"passingScore\": null}, {\"name\": \"Semestrální práce\", \"type\": \"project\", \"weight\": 50, \"maxScore\": null, \"description\": \"\", \"passingScore\": null}, {\"name\": \"Závěrečný test\", \"type\": \"exam\", \"weight\": 30, \"maxScore\": null, \"description\": \"\", \"passingScore\": null}, {\"name\": \"Průběžný test\", \"type\": \"test\", \"weight\": 10, \"maxScore\": null, \"description\": \"\", \"passingScore\": null}], \"literature\": {\"required\": [\"BRUCKNER, Tomáš; BUCHALCEVOVÁ, Alena; CHLAPEK, Dušan; STANOVSKÁ, Iva; VOŘÍŠEK, Jiří; ŘEPA, Václav. Tvorba informačních systémů : principy, metodiky, architektury. Praha: Grada Publishing, 2012.\", \"ISBN 978-80-247-4153-6.\", \"BUCHALCEVOVÁ, Alena a STANOVSKÁ, Iva. Příklady modelů analýzy a návrhu aplikace v UML. Praha: Oeconomica, 2013.\", \"ISBN 978-80-245-1922-7.\", \"BUCHALCEVOVÁ, Alena. Zlepšování procesů při budování informačních systémů. Praha: Oeconomica, nakladatelství VŠE, 2018.\", \"ISBN 978-80-245-2235-7.\"], \"recommended\": [\"PECINOVSKÝ, Rudolf. Návrhové vzory. Brno: Computer Press, 2007.\", \"ISBN 978-80-251-1582-4.\"]}, \"description\": \"Cílem předmětu je podat základní představu o disciplíně softwarové inženýrství se zaměřením na návrh a implementaci nového programového systému. \\nPředmět předpokládá předchozí absolvování kurzu 4IT101 Programování v Javě. Předmět pokrývá následující tematické okruhy oblasti vzdělávání Informatika: Programovací jazyky a paradigmata, Programování, Softwarové inženýrství, Uživatelská rozhraní a Počítačové architektury.\", \"allLecturers\": [\"prof. Ing. Alena Buchalcevová, Ph.D. (přednášející, zkoušející)\", \"Ing. Jakub Salavec (cvičící, zkoušející)\", \"Ing. Filip Vencovský, Ph.D. (cvičící, garant, přednášející, zkoušející)\", \"Bc. Jan Veverka (cvičící, zkoušející)\"], \"gradingScale\": [{\"grade\": \"1\", \"label\": \"Výborně\", \"minPercent\": 90}, {\"grade\": \"2\", \"label\": \"Velmi dobře\", \"minPercent\": 75}, {\"grade\": \"3\", \"label\": \"Dobře\", \"minPercent\": 60}, {\"grade\": \"4\", \"label\": \"Nedostatečně\", \"minPercent\": 0}], \"requirements\": [], \"weeklyTopics\": [], \"learningOutcomes\": [\"Po úspěšném absolvování předmětu budou studenti mít přehled o oblasti softwarového inženýrství a praktické zkušenosti s analýzou požadavků, návrhem a implementací aplikace. Budou schopni vytvářet UML modely\", \"diagram případů užití, diagram tříd na návrhové úrovni, sekvenční diagram a diagram aktivit, navrhovat uživatelské rozhraní, realizovat aplikaci s grafickým uživatelským rozhraním v JavaFX.\"]},\"ai_summary\":\"Naučíš se jak se vyvíjí software od nápadu po nasazení.\",\"status\":\"validated\",\"submitted_by\":\"\",\"validated_at\":\"2026-03-17T14:14:49.2814+00:00\",\"created_at\":\"2026-03-17T14:14:49.2814+00:00\"}, \n {\"id\":\"2641bdff-3c6e-4a19-83c6-98ff835289c2\",\"code\":\"4IT563\",\"semester\":\"LS 2025/26\",\"data\":{\"code\": \"4IT563\", \"name\": \"Architektury business analytiky (v angličtině)\", \"group\": \"povinny\", \"credits\": 3, \"insisUrl\": \"https://insis.vse.cz/auth/katalog/syllabus.pl?predmet=215502&lang=cz&typ=1&jazyk=1&vystup=1\", \"lecturer\": \"doc. Ing. Miloš Maryška, Ph.D.\", \"schedule\": [], \"semester\": \"LS 2025/2026\", \"workload\": {\"total\": 78, \"project\": 0, \"examPrep\": 26, \"lectures\": 10, \"seminars\": 26, \"testPrep\": 0}, \"aiSummary\": \"\", \"components\": [{\"name\": \"Aktivita na přednáškách/cvičeních/seminářích\", \"type\": \"attendance\", \"weight\": 20, \"maxScore\": null, \"description\": \"\", \"passingScore\": null}, {\"name\": \"Prezentace nebo obhajoba\", \"type\": \"other\", \"weight\": 30, \"maxScore\": null, \"description\": \"\", \"passingScore\": null}, {\"name\": \"Absolvování závěrečné ústní zkoušky\", \"type\": \"exam\", \"weight\": 50, \"maxScore\": null, \"description\": \"\", \"passingScore\": null}], \"literature\": {\"required\": [\"JOHN, Tomcy; MISRA, Pankaj. Data lake for enterprises : leveraging lambda architecture for building enterprise data lake. Birmingham: Packt Publishing, 2017. ISBN 978-1-78728-134-9.\", \"BRACKETT, Michael H. Data sharing : using a common data architecture. New York: John Wiley & Sons, 1994. ISBN 0-471-30993-1.\"], \"recommended\": []}, \"description\": \"Předmět se zaměřuje na specifikaci a vysvětlení základních stavebních bloků v oblasti architektury business analytiky po stránce teoretické i praktické. Účelem je objasnit různé typy architektur v BA, jejich principy a charakteristiky a od nich odvozované přístupy k řešením. Dále pochopit data, datové zdroje, datové struktury a možnosti přístupu k datům a jejich využívání.\", \"allLecturers\": [\"Ing. Vít Hanzal(cvičící, zkoušející)\", \"doc. Ing. Miloš Maryška, Ph.D.(garant)\"], \"gradingScale\": [{\"grade\": \"Kód předmětu:\", \"label\": \"4IT563\", \"minPercent\": 0}, {\"grade\": \"Semestr:\", \"label\": \"LS 2025/2026\", \"minPercent\": 0}], \"requirements\": [], \"weeklyTopics\": [{\"week\": 1, \"topic\": \"Business\", \"content\": \"\"}, {\"week\": 2, \"topic\": \"Aplikační\", \"content\": \"\"}, {\"week\": 3, \"topic\": \"Datová / informační\", \"content\": \"\"}, {\"week\": 4, \"topic\": \"Technologická\", \"content\": \"\"}, {\"week\": 5, \"topic\": \"Enteprise architektura a solution architektura\", \"content\": \"\"}, {\"week\": 6, \"topic\": \"Standardy v oblasti architektur\", \"content\": \"\"}, {\"week\": 7, \"topic\": \"Účel, využití v BA řešení\", \"content\": \"\"}, {\"week\": 8, \"topic\": \"Datové modelování\", \"content\": \"\"}, {\"week\": 9, \"topic\": \"Relevantní komponenty (DWH, Data Lake, ETL, MDM, metadatové nástroje, ODS, IoT)\", \"content\": \"\"}, {\"week\": 10, \"topic\": \"Datové principy – datové struktury, kategorie dat, využitelnost v BA úlohách\", \"content\": \"\"}, {\"week\": 11, \"topic\": \"Datová kvalita\", \"content\": \"\"}, {\"week\": 12, \"topic\": \"Master Data Management\", \"content\": \"\"}, {\"week\": 13, \"topic\": \"Reference Data Management\", \"content\": \"\"}, {\"week\": 14, \"topic\": \"Metadata Management\", \"content\": \"\"}, {\"week\": 15, \"topic\": \"Nestrukturovaná data\", \"content\": \"\"}, {\"week\": 16, \"topic\": \"Big Data\", \"content\": \"\"}, {\"week\": 17, \"topic\": \"Specifické datové zdroje\", \"content\": \"\"}, {\"week\": 18, \"topic\": \"Nástroje pro Data Management\", \"content\": \"\"}, {\"week\": 19, \"topic\": \"Operations\", \"content\": \"\"}, {\"week\": 20, \"topic\": \"Bezpečnost\", \"content\": \"\"}, {\"week\": 21, \"topic\": \"Maturity assessment\", \"content\": \"\"}, {\"week\": 22, \"topic\": \"finance – banky / pojišťovny\", \"content\": \"\"}, {\"week\": 23, \"topic\": \"farmacie / healthcare\", \"content\": \"\"}, {\"week\": 24, \"topic\": \"průmysl\", \"content\": \"\"}, {\"week\": 25, \"topic\": \"retail\", \"content\": \"\"}, {\"week\": 26, \"topic\": \"energy / utility\", \"content\": \"\"}, {\"week\": 27, \"topic\": \"telco\", \"content\": \"\"}], \"learningOutcomes\": [\"Po úspěšném absolvování budou studenti schopni diskutovat:\", \"1. Základy práce datového architekta\", \"2. Přínosy datové architektury pro organizaci\", \"3. Jednotlivé typy architektur, principy a charakteristiky\", \"4. Postupy návrhu základních stavebních bloků architektury v oblasti business analytiky\", \"5. Jakými aspekty je nutné se zabývat v souvislosti s budováním a řízením architektury business analytiky v podniku\", \"6. Jak jednoznačně a správně definovaná architektura napomáhá k udržitelnosti rozvoje business analytiky v organizaci\"]},\"ai_summary\":\"\",\"status\":\"validated\",\"submitted_by\":\"\",\"validated_at\":null,\"created_at\":\"2026-04-01T18:02:23.49372+00:00\"}, \n {\"id\":\"bb87ccb9-5182-4caf-abdb-1bfd05b96f2a\",\"code\":\"4ITCZV005\",\"semester\":\"LS 2025/26\",\"data\":{\"code\": \"4ITCZV005\", \"name\": \"Actuarial models - Životní pojištění\", \"group\": \"povinny\", \"credits\": 7, \"insisUrl\": \"https://insis.vse.cz/auth/katalog/syllabus.pl?predmet=222175&lang=cz&typ=1&jazyk=1&vystup=1\", \"lecturer\": \"Ing. Pavel Zimmermann, Ph.D.\", \"schedule\": [], \"semester\": \"LS 2025/2026\", \"workload\": {\"total\": 0, \"project\": 0, \"examPrep\": 0, \"lectures\": 0, \"seminars\": 0, \"testPrep\": 0}, \"aiSummary\": \"\", \"components\": [], \"literature\": {\"required\": [], \"recommended\": []}, \"description\": \"-- obsah této položky nebyl definován --\", \"allLecturers\": [\"Ing. Pavel Zimmermann, Ph.D.(garant)\"], \"gradingScale\": [{\"grade\": \"Kód předmětu:\", \"label\": \"4ITCZV005\", \"minPercent\": 0}, {\"grade\": \"Semestr:\", \"label\": \"LS 2025/2026\", \"minPercent\": 0}], \"requirements\": [], \"weeklyTopics\": [], \"learningOutcomes\": [\"-- obsah této položky nebyl definován --\"]},\"ai_summary\":\"\",\"status\":\"validated\",\"submitted_by\":\"\",\"validated_at\":null,\"created_at\":\"2026-04-01T18:02:23.49372+00:00\"}, \n {\"id\":\"3244e7bc-1201-4169-a282-e207765e7c44\",\"code\":\"4ITCZV006\",\"semester\":\"LS 2025/26\",\"data\":{\"code\": \"4ITCZV006\", \"name\": \"Actuarial models - Neživotní pojištění\", \"group\": \"povinny\", \"credits\": 7, \"insisUrl\": \"https://insis.vse.cz/auth/katalog/syllabus.pl?predmet=222174&lang=cz&typ=1&jazyk=1&vystup=1\", \"lecturer\": \"Ing. Pavel Zimmermann, Ph.D.\", \"schedule\": [], \"semester\": \"LS 2025/2026\", \"workload\": {\"total\": 0, \"project\": 0, \"examPrep\": 0, \"lectures\": 0, \"seminars\": 0, \"testPrep\": 0}, \"aiSummary\": \"\", \"components\": [], \"literature\": {\"required\": [], \"recommended\": []}, \"description\": \"-- obsah této položky nebyl definován --\", \"allLecturers\": [\"Ing. Pavel Zimmermann, Ph.D.(garant)\"], \"gradingScale\": [{\"grade\": \"Kód předmětu:\", \"label\": \"4ITCZV006\", \"minPercent\": 0}, {\"grade\": \"Semestr:\", \"label\": \"LS 2025/2026\", \"minPercent\": 0}], \"requirements\": [], \"weeklyTopics\": [], \"learningOutcomes\": [\"-- obsah této položky nebyl definován --\"]},\"ai_summary\":\"\",\"status\":\"validated\",\"submitted_by\":\"\",\"validated_at\":null,\"created_at\":\"2026-04-01T18:02:23.49372+00:00\"}]"
